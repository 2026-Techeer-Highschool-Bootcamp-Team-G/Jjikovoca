# 로컬 시크릿 예시 — 복사 후 채우기: cp .env.example .env  (.env는 커밋 금지)
# 프로덕션은 SSM Parameter Store에서 주입되며 이 파일을 쓰지 않는다 (08 §7)

# DB
DB_USER=jjik
DB_PASSWORD=jjik
DB_ROOT_PASSWORD=root

# Redis (로컬은 compose 기본값이라 미설정 시 localhost:6379)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Gemini — 키 없으면 모의 AI 모드(GEMINI_MOCK=true)로 팀원 온보딩 가능 (13 §8-4)
GEMINI_MOCK=true
# GEMINI_API_KEY=
